{
  "author": "Quentin DI MEO",
  "name": "plume",
  "license": "MIT",
  "version": "1.11.0",
  "description": "Bandcamp extension: volume slider, click-to-seek progress bar, loop modes, fullscreen mode & hotkeys for the player.",
  "scripts": {
    "build": "node scripts/build.js --dev",
    "build:watch": "node scripts/build.js --dev --watch",
    "build:prod": "node scripts/build.js",
    "build:test": "node scripts/build.js --test",
    "clean": "rimraf dist build",
    "sync-version": "node scripts/sync-version.js",
    "package": "tsc --noEmit && pnpm build:prod && node scripts/package-deployer.js",
    "deploy": "pnpm clean && pnpm sync-version && pnpm package",
    "lint": "pnpm prettier && pnpm eslint",
    "eslint": "eslint src/**/*.ts",
    "eslint:fix": "eslint src/**/*.ts --fix",
    "prettier": "prettier --check 'src/**/*.{ts,js,json,css,html}' 'tests/**/*.ts'",
    "prettier:fix": "prettier --write 'src/**/*.{ts,js,json,css,html}' 'tests/**/*.ts'",
    "format": "pnpm prettier:fix && pnpm eslint:fix",
    "prepare": "tsc --noEmit && husky",

    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage --coverage.skipFull",
    "test:cov:report": "vitest run --coverage --reporter=verbose",

    "zip": "node scripts/zip-sources.js"
  },
  "keywords": [
    "bandcamp",
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "typescript",
    "audio-player",
    "volume-control",
    "music-player",
    "bandcamp-enhancer",
    "seek-bar",
    "fullscreen",
    "web-extension",
    "manifest-v3"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.33.0",
    "@types/chrome": "^0.1.4",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,js,json,css,html}": [
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ]
  }
}
