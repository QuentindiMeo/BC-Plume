{
  "author": "Quentin DI MEO",
  "name": "bc-plume",
  "license": "MIT",
  "version": "1.3.1",
  "description": "Improves the Bandcamp player interface with a volume slider and enhanced playback controls.",
  "scripts": {
    "build": "node scripts/build.js --dev",
    "build:watch": "node scripts/build.js --dev --watch",
    "build:prod": "node scripts/build.js",
    "clean": "rimraf dist build",
    "dev": "pnpm clean && pnpm build:watch",
    "sync-version": "node scripts/sync-version.js",
    "package": "pnpm build:prod && node scripts/package-deployer.js",
    "deploy": "pnpm clean && pnpm sync-version && pnpm package",

    "lint": "pnpm prettier && pnpm eslint",
    "eslint": "eslint src/**/*.ts",
    "eslint:fix": "eslint src/**/*.ts --fix",
    "prettier": "prettier --check 'src/**/*.{ts,js,json,css,html}'",
    "prettier:fix": "prettier --write 'src/**/*.{ts,js,json,css,html}'",
    "format": "pnpm prettier:fix && pnpm eslint:fix",
    "prepare": "husky"
  },
  "keywords": [
    "bandcamp",
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "typescript",
    "audio-player"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.33.0",
    "@types/chrome": "^0.1.4",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,js,json,css,html}": [
      "prettier --write"
    ]
  }
}
